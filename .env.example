# ============================================================
# JurneeGo Safe AI Learning Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------- Database ----------
DATABASE_URL=postgresql://jurnee:jurnee_secret@db:5432/jurnee_ai

# ---------- AI Provider ----------
# Options: "mock" | "bedrock" | "litellm"
# Start with "mock" for local dev (no external API needed)
AI_PROVIDER=mock

# ---------- AWS Bedrock (when AI_PROVIDER=bedrock) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ---------- LiteLLM (when AI_PROVIDER=litellm) ----------
LITELLM_API_BASE=http://litellm:4000
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=sk-your-litellm-key

# ---------- Authentication ----------
# Comma-separated list of valid API keys
API_KEYS=jurnee-demo-key-change-me,another-key-optional

# ---------- Safety ----------
SAFETY_ENABLED=true
# Optional: use LLM for deeper safety checks (slower but smarter)
SAFETY_LLM_CHECK=false

# ---------- Application ----------
APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
