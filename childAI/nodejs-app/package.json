{
  "name": "childai-nodejs-backend",
  "version": "1.0.0",
  "description": "Child-safe AI learning assistant backend - Node.js/TypeScript rebuild",
  "main": "dist/server.js",
  "scripts": {
    "dev": "env $(cat .env | grep -v '#' | xargs) npx tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/type-provider-typebox": "^4.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/instrumentation-fastify": "^0.36.1",
    "@opentelemetry/instrumentation-http": "^0.52.1",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@sinclair/typebox": "^0.32.34",
    "@testcontainers/postgresql": "^11.14.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jose": "^5.4.1",
    "kysely": "^0.27.3",
    "node-pg-migrate": "^7.5.0",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitest/coverage-v8": "^2.0.4",
    "@vitest/ui": "^2.0.4",
    "eslint": "^8.57.0",
    "testcontainers": "^10.10.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "undici": "^6.19.7",
    "vitest": "^2.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
