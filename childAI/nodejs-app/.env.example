# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://jurnee:jurnee_secret@localhost:5432/jurnee_ai

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_MODE=jwt
JWT_ISSUER=http://localhost:9000
JWT_AUDIENCE=childai-api
JWT_JWKS_URL=http://localhost:9000/.well-known/jwks.json
# Dev-only fallback (disabled in production)
DEV_API_KEY=dev-local-api-key-change-me
DEV_JWT_SECRET=dev-local-jwt-secret-change-me-32chars!!

# AI Providers
AI_PROVIDER_MODE=fallback
AI_PROVIDER_ORDER=mock,litellm,bedrock

# AWS Bedrock (local dev: use keys; production: use IAM role)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# LiteLLM
LITELLM_API_BASE=http://localhost:4000/v1
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=sk-local-dev-key

# Safety
SAFETY_ENABLED=true
SAFETY_LLM_CHECK=false
SAFETY_STREAM_MODE=buffered

# SSE / Streaming
SSE_HEARTBEAT_SECONDS=15
AI_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=512

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=childai-nodejs
